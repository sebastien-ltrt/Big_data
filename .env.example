# ============================================================
# .env.example — Parkings Rennes Big Data Pipeline
# Copiez ce fichier : cp .env.example .env
# ============================================================

# ── API Citedia (10 parkings centre-ville) ────────────────────
CITEDIA_API_URL=http://data.citedia.com/r1/parks

# ── API STAR Rennes Métropole (8 parcs-relais P+R) ────────────
STAR_API_BASE_URL=https://data.explore.star.fr/api/explore/v2.1
# Optionnel — clé API pour lever les limites de débit
# STAR_API_KEY=votre_cle_api

# ── Scraping météo ────────────────────────────────────────────
WEATHER_URL=https://wttr.in/Rennes

# ── PostgreSQL — Data Warehouse ───────────────────────────────
# En local (hors Docker) : localhost
# Dans Docker Compose    : postgres-parkings
PG_HOST=localhost
PG_PORT=5434
PG_DB=parkings_rennes
PG_USER=parking_user
PG_PASSWORD=parking2024

# ── MinIO — Data Lake (S3-compatible) ─────────────────────────
# En local (hors Docker) : localhost:9000
# Dans Docker Compose    : minio:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=parkings-raw
MINIO_BUCKET_PROCESSED=parkings-processed
MINIO_SECURE=false

# ── Dashboard Streamlit ───────────────────────────────────────
DASHBOARD_PORT=8501
